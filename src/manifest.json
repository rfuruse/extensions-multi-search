{
  "name": "Multi Search",
  "description": "Search multiple engines simultaneously",
  "version": "0.1",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "ms"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}